<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchDia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        app:thumbTint="@color/citas_primary"
        app:trackTint="@color/citas_secondary"/>

    <TextView
        android:id="@+id/tvNombreDia"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Lunes"
        android:textSize="14sp"
        android:textColor="#030229"
        android:fontFamily="sans-serif-medium"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:background="@drawable/bg_input"
        android:backgroundTint="#F8F9FB"
        android:gravity="center"
        android:paddingHorizontal="8dp">
        <TextView
            android:id="@+id/tvHoraInicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textColor="#030229"
            android:textSize="13sp"/>
        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_clock"
            app:tint="#A0A0B2"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="a"
        android:layout_marginHorizontal="6dp"
        android:textColor="#A0A0B2"
        android:textSize="12sp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:background="@drawable/bg_input"
        android:backgroundTint="#F8F9FB"
        android:gravity="center"
        android:paddingHorizontal="8dp">
        <TextView
            android:id="@+id/tvHoraFin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="17:00"
            android:textColor="#030229"
            android:textSize="13sp"/>
        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_clock"
            app:tint="#A0A0B2"/>
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configuración de Horarios"
                android:textSize="20sp"
                android:textColor="@color/citas_primary"
                android:textStyle="bold"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">
            <Button
                android:id="@+id/btnEditarHorario"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/citas_primary"
                android:text="Editar"
                android:visibility="gone" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:text="Seleccionar Unidad"
                android:textColor="@color/citas_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

            <Spinner
                android:id="@+id/spUnidades"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginEnd="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:padding="8dp"
                android:popupBackground="@color/citas_background" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#ECECF3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tabs"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horarios de la Clínica"
                        android:textColor="#030229"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="20dp"/>

                    <include layout="@layout/item_horario_dia" android:id="@+id/itemLunes" />
                    <include layout="@layout/item_horario_dia" android:id="@+id/itemMartes" />
                    <include layout="@layout/item_horario_dia" android:id="@+id/itemMiercoles" />
                    <include layout="@layout/item_horario_dia" android:id="@+id/itemJueves" />
                    <include layout="@layout/item_horario_dia" android:id="@+id/itemViernes" />
                    <include layout="@layout/item_horario_dia" android:id="@+id/itemSabado" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tabs"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:alpha="0.6">
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchDomingo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:enabled="false"/>
                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Domingo"
                            android:layout_marginStart="12dp"
                            android:textColor="#6A6A80"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="Cerrado"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:background="@drawable/bg_input"
                            android:backgroundTint="#F1F1F5"
                            android:textColor="#6A6A80"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#ECECF3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tabs"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Turnos Especiales"
                        android:textColor="#030229"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFAEB"
                        app:strokeWidth="1dp"
                        app:strokeColor="#FEF0C7">
                        <RelativeLayout
                            android:padding="16dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true">
                                <TextView
                                    android:text="Turno de Emergencias"
                                    android:textColor="#B54708"
                                    android:textStyle="bold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView
                                    android:text="24/7 disponible"
                                    android:textColor="#B54708"
                                    android:textSize="12sp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchEmergencia"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                app:thumbTint="@color/citas_primary"
                                app:trackTint="@color/citas_secondary"/>
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F0F9FF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#B9E6FE">
                        <RelativeLayout
                            android:padding="16dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true">
                                <TextView
                                    android:text="Turno Nocturno"
                                    android:textColor="#026AA2"
                                    android:textStyle="bold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                                <TextView
                                    android:text="17:00 - 07:00"
                                    android:textColor="#026AA2"
                                    android:textSize="12sp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchNocturno"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:thumbTint="@color/citas_primary"
                                app:trackTint="@color/citas_secondary"/>
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarHorario"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:text="Guardar Cambios"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="@color/citas_secondary"
                android:layout_gravity="center_horizontal"
                app:cornerRadius="8dp"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
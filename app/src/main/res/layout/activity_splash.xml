<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/citas_background"
    android:gravity="center_horizontal"
    tools:context=".ui.SplashActivity">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="136dp"
        android:layout_height="136dp"
        android:layout_marginTop="44dp"
        android:padding="20dp"
        android:src="@drawable/citas_medicas_logo"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Citas Médicas"
        android:textColor="@color/citas_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Instituto Salvadoreño del Seguro Social"
        android:textColor="@color/citas_primary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    <LinearLayout
        android:id="@+id/layoutFeatures"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

    </LinearLayout>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="42dp"
        android:backgroundTint="@color/citas_secondary"
        android:text="Iniciar Sesión"
        android:textAllCaps="false"
        android:textColor="@color/citas_primary"
        app:cornerRadius="12dp" />

    <Button
        android:id="@+id/btnRegister"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Registrarse"
        android:textAllCaps="false"
        android:textColor="@color/citas_primary"
        app:cornerRadius="12dp"
        app:strokeColor="@color/citas_secondary" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Versión 1.0.0"
        android:textColor="@color/citas_primary"
        android:textSize="12sp" />

</LinearLayout>